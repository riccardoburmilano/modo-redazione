<script>
function sub(){
  const e=document.getElementById('email');
  if(!e.value||!e.value.includes('@'))return;
  localStorage.setItem('quota_email',e.value);
  e.style.display='none';document.querySelector('.signup-btn').style.display='none';
  document.getElementById('sub-ok').style.display='block';
}

// Anima counter stats
function animateN(el,target,suffix){
  let n=0;const s=target/60;
  const t=setInterval(()=>{n=Math.min(target,n+s);el.textContent=Math.floor(n).toLocaleString('it-IT')+(suffix||'');if(n>=target)clearInterval(t);},16);
}

const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      animateN(document.getElementById('s-users'),2847);
      animateN(document.getElementById('s-quota'),143);
      obs.disconnect();
    }
  });
},{threshold:.3});
obs.observe(document.querySelector('.stats'));
</script>

<script>
function onTelegramAuth(user){
  // Salva dati utente Telegram in localStorage
  localStorage.setItem('quota_tg_id', user.id);
  localStorage.setItem('quota_tg_name', user.first_name+(user.last_name?' '+user.last_name:''));
  localStorage.setItem('quota_tg_username', user.username||'');
  localStorage.setItem('quota_tg_photo', user.photo_url||'');
  
  // Token = telegram_id (permanente)
  const token = 'tg_'+user.id;
  localStorage.setItem('quota_token', token);
  
  // Registra su backend
  fetch('https://god-core-backend.onrender.com/api/v2/quota/auth/telegram', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({
      telegram_id: user.id,
      name: user.first_name+(user.last_name?' '+user.last_name:''),
      username: user.username||'',
      photo_url: user.photo_url||'',
      token: token
    })
  }).catch(()=>{});
  
  // Mostra benvenuto e redirect
  document.getElementById('tg-login-wrap').innerHTML = 
    '<div style="display:flex;align-items:center;gap:10px;background:rgba(0,232,122,.08);border:1px solid rgba(0,232,122,.2);border-radius:10px;padding:12px 16px">'
    +(user.photo_url?'<img src="'+user.photo_url+'" style="width:36px;height:36px;border-radius:50%">':'<div style="width:36px;height:36px;border-radius:50%;background:rgba(168,85,247,.3);display:flex;align-items:center;justify-content:center;font-size:16px">⚡</div>')
    +'<div><div style="font-family:var(--sg);font-size:13px;font-weight:700;color:#00e87a">✓ Connesso come '+user.first_name+'</div>'
    +'<div style="font-size:11px;color:var(--t2);margin-top:2px">'+(user.username?'@'+user.username:'Telegram ID: '+user.id)+'</div></div>'
    +'<a href="quota.html" style="margin-left:auto;padding:8px 16px;background:var(--gold);color:#000;font-family:var(--sg);font-size:12px;font-weight:800;border-radius:8px;text-decoration:none">Entra →</a>'
    +'</div>';
}

// Auto-login se già connesso
const savedTgId = localStorage.getItem('quota_tg_id');
if(savedTgId){
  const name = localStorage.getItem('quota_tg_name')||'Utente';
  const username = localStorage.getItem('quota_tg_username')||'';
  const photo = localStorage.getItem('quota_tg_photo')||'';
  setTimeout(()=>{
    const wrap = document.getElementById('tg-login-wrap');
    if(wrap) wrap.innerHTML = 
      '<div style="display:flex;align-items:center;gap:10px;background:rgba(0,232,122,.08);border:1px solid rgba(0,232,122,.2);border-radius:10px;padding:12px 16px">'
      +(photo?'<img src="'+photo+'" style="width:36px;height:36px;border-radius:50%">':'<div style="width:36px;height:36px;border-radius:50%;background:rgba(168,85,247,.3);display:flex;align-items:center;justify-content:center;font-size:16px">⚡</div>')
      +'<div><div style="font-family:var(--sg);font-size:13px;font-weight:700;color:#00e87a">✓ '+name+'</div>'
      +'<div style="font-size:11px;color:var(--t2);margin-top:2px">'+(username?'@'+username:'')+'</div></div>'
      +'<a href="quota.html" style="margin-left:auto;padding:8px 16px;background:var(--gold);color:#000;font-family:var(--sg);font-size:12px;font-weight:800;border-radius:8px;text-decoration:none">Entra →</a>'
      +'</div>';
  }, 500);
}
</script></body>
